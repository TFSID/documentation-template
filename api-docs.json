{
  "openapi": "3.0.0",
  "info": {
    "title": "My Laravel API",
    "description": "Dokumentasi API untuk frontend",
    "version": "1.0.0"
  },
  "paths": {
    "/api/register": {
      "post": {
        "tags": [
          "Auth"
        ],
        "summary": "Register user baru",
        "operationId": "8a56853624e025573120a09a4c75d468",
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "required": [
                  "nama_lengkap",
                  "jenis_kelamin",
                  "tgl_lahir",
                  "email",
                  "no_handphone",
                  "password",
                  "role"
                ],
                "properties": {
                  "nama_lengkap": {
                    "type": "string",
                    "example": "John Doe"
                  },
                  "jenis_kelamin": {
                    "type": "string",
                    "enum": [
                      "laki-laki",
                      "perempuan"
                    ],
                    "example": "laki-laki"
                  },
                  "tgl_lahir": {
                    "type": "string",
                    "format": "date",
                    "example": "2000-01-01"
                  },
                  "email": {
                    "type": "string",
                    "format": "email",
                    "example": "john@example.com"
                  },
                  "no_handphone": {
                    "type": "string",
                    "example": "08123456789"
                  },
                  "password": {
                    "type": "string",
                    "format": "password",
                    "example": "password123"
                  },
                  "role": {
                    "type": "string",
                    "enum": [
                      "user",
                      "mitra",
                      "superadmin"
                    ],
                    "example": "user"
                  },
                  "foto_profile": {
                    "description": "Profile picture (jpg, jpeg, png)",
                    "type": "string",
                    "format": "binary"
                  }
                },
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "User registered successfully"
          },
          "422": {
            "description": "Validation error"
          }
        }
      }
    },
    "/api/login": {
      "post": {
        "tags": [
          "Auth"
        ],
        "summary": "Login pengguna",
        "operationId": "a3b306d14572d1f4bd6c064b3233e7b8",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "required": [
                  "email",
                  "password"
                ],
                "properties": {
                  "email": {
                    "type": "string",
                    "example": "john@example.com"
                  },
                  "password": {
                    "type": "string",
                    "example": "password123"
                  }
                },
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login success",
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "message": {
                      "type": "string",
                      "example": "Login success"
                    },
                    "user": {
                      "type": "object"
                    },
                    "role": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    },
                    "token": {
                      "type": "string",
                      "example": "Bearer \u003Ctoken\u003E"
                    }
                  },
                  "type": "object"
                }
              }
            }
          },
          "422": {
            "description": "Validation error"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/api/me": {
      "get": {
        "tags": [
          "Auth"
        ],
        "summary": "Ambil data user yang sedang login (profile)",
        "operationId": "9d9bc556f927575aa492a88c28fe5908",
        "responses": {
          "200": {
            "description": "User profile",
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "id": {
                      "type": "integer",
                      "example": 1
                    },
                    "nama_lengkap": {
                      "type": "string",
                      "example": "John Doe"
                    },
                    "jenis_kelamin": {
                      "type": "string",
                      "example": "laki-laki"
                    },
                    "tgl_lahir": {
                      "type": "string",
                      "format": "date",
                      "example": "2000-01-01"
                    },
                    "email": {
                      "type": "string",
                      "example": "john@example.com"
                    },
                    "no_handphone": {
                      "type": "string",
                      "example": "08123456789"
                    },
                    "foto_profile": {
                      "description": "\u003Cimg src='http://localhost:8000/storage/profile/foo.jpg' width='120' /\u003E",
                      "type": "string",
                      "format": "uri",
                      "example": "http://localhost:8000/storage/profile/foo.jpg",
                      "nullable": true
                    },
                    "roles": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    }
                  },
                  "type": "object"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ]
      }
    },
    "/api/logout": {
      "post": {
        "tags": [
          "Auth"
